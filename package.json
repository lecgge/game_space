{
  "name": "game_space",
  "version": "1.0.0",
  "description": "Game Space - Local PC Game Library Manager",
  "main": "src/main.js",
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "scripts": {
    "electron": "electron .",
    "dev": "vite",
    "build": "vite build",
    "electron:build": "vite build && electron-builder",
    "electron:pack": "electron-builder --dir",
    "run": "npm run electron"
  },
  "build": {
    "appId": "com.gamespace.app",
    "productName": "Game Space",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  },
  "dependencies": {
    "@phosphor-icons/react": "^2.1.7",
    "@radix-ui/react-icons": "^1.3.2",
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.15.0",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.3.0",
    "tailwindcss-animate": "^1.0.7",
    "vite": "^6.0.3",
    "vite-plugin-electron": "^1.0.4",
    "wait-on": "^8.0.1"
  }
}
